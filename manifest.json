{
    "manifest_version": 3,
    "name": "__MSG_extName__",
    "version": "3.1.4",
    "description": "__MSG_extDesc__",
    "default_locale": "en",
    "chrome_url_overrides": {
        "newtab": "index.html"
    },
    "optional_host_permissions": [
        "https://*/*"
    ],
    "icons": {
        "16": "icon/icon16.png",
        "48": "icon/icon48.png",
        "128": "icon/icon128.png"
    },
    "permissions": [
        "search"
    ],
    "content_security_policy": {
        "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; img-src 'self' https: data: blob:; style-src 'self'"
    }
}
