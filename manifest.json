{
    "manifest_version": 3,
    "name": "__MSG_extName__",
    "version": "3.0.2",
    "description": "__MSG_extDesc__",
    "default_locale": "en",
    "chrome_url_overrides": {
        "newtab": "index.html"
    },
    "icons": {
        "16": "icon/icon16.png",
        "48": "icon/icon48.png",
        "128": "icon/icon128.png"
    },
    "permissions": ["search"],
    "content_security_policy": {
        "extension_pages": "script-src 'self'; object-src 'self'; img-src 'self' https://bing.biturl.top https://bing.img.run data: blob:; style-src 'self'"
    }
}